# --- Telegram Bot Configuration ---
# Your Telegram Bot Token obtained from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Comma-separated list of Telegram User IDs allowed to use the bot (for security)
# You can find your ID using @userinfobot
ALLOWED_TELEGRAM_USERS=123456789,987654321

# --- Storage Settings (Optional) ---
# Directory where files and subdirectories will be saved (Obsidian Vault compatible)
# Defaults to a folder named "library" in the project root
# RIL_LIBRARY_DIR=/Users/username/Obsidian/Vaults/ReadLater

# Database location for metadata and FTS5 search index
# Defaults to metadata.db inside RIL_LIBRARY_DIR
# RIL_DB_PATH=/Users/username/Obsidian/Vaults/ReadLater/metadata.db

# --- Crawler Settings (Optional) ---
# Run browser in headless mode (default: true)
RIL_CRAWLER_HEADLESS=true

# Enable stealth plugins to bypass Cloudflare and basic scrapers protection (default: true)
RIL_CRAWLER_STEALTH=true

# Playwright page load timeout in milliseconds (default: 30000)
RIL_CRAWLER_TIMEOUT_MS=30000
